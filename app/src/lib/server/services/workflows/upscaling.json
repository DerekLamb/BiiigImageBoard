{
  "_comment": "ComfyUI API-format workflow for image upscaling using RealESRGAN or similar upscaler. PLACEHOLDER - Customize upscaler model name to match your setup.",
  "3": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "INPUT_FILENAME_PLACEHOLDER",
      "upload": "image"
    }
  },
  "4": {
    "class_type": "UpscaleModelLoader",
    "inputs": {
      "model_name": "RealESRGAN_x4plus.pth"
    }
  },
  "5": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": {
      "upscale_model": ["4", 0],
      "image": ["3", 0]
    }
  },
  "6": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["5", 0],
      "filename_prefix": "upscaled"
    }
  }
}
