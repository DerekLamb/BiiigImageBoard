{
  "_comment": "ComfyUI API-format workflow for img2img detail cleanup (faces, eyes, details). Uses low denoise img2img pass. PLACEHOLDER - Customize model and prompt to match your workflow.",
  "3": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "INPUT_FILENAME_PLACEHOLDER",
      "upload": "image"
    }
  },
  "4": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["3", 0],
      "vae": ["5", 2]
    }
  },
  "5": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "v1-5-pruned-emaonly.ckpt"
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "high quality, detailed, sharp focus, clean, well lit",
      "clip": ["5", 1]
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "blur, blurry, low quality, artifacts, deformed, bad anatomy, bad eyes, extra limbs",
      "clip": ["5", 1]
    }
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["5", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["4", 0],
      "seed": 8566257,
      "steps": 15,
      "cfg": 7,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 0.25
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["8", 0],
      "vae": ["5", 2]
    }
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["9", 0],
      "filename_prefix": "img2img_cleanup"
    }
  }
}
