# MongoDB - only needed when running outside Docker
# DB_URI = 'mongodb://localhost:27017'

# Authentication secrets (generate your own)
AUTH_SECRET = "your-random-secret-here"
BETTER_AUTH_SECRET = "your-better-auth-secret-here"
BETTER_AUTH_URL = "https://your-domain.com"
PUBLIC_BETTER_AUTH_URL = "https://your-domain.com"

# Admin account (created on first sign-up)
ADMIN_EMAIL = "admin@example.com"
ADMIN_PASSWORD = "your-admin-password"

# Upload limit (set to Infinity for large files)
BODY_SIZE_LIMIT = Infinity
